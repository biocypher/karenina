  "dataFeedElement": [
    {
      "@type": "DataFeedItem",
      "@id": "urn:karenina:test:q001",
      "dateCreated": "2025-01-11T00:00:00Z",
      "dateModified": "2025-01-11T00:00:00Z",
      "item": {
        "@type": "Question",
        "@id": "urn:karenina:test:q001-question",
        "text": "What is 2+2?",
        "acceptedAnswer": {
          "@type": "Answer",
          "@id": "urn:karenina:test:q001-answer",
          "text": "4"
        },
        "hasPart": {
          "@type": "SoftwareSourceCode",
          "@id": "urn:karenina:test:q001-template",
          "name": "Simple Addition Answer Template",
          "text": "from karenina.schemas.entities import BaseAnswer\nfrom pydantic import Field\n\nclass Answer(BaseAnswer):\n    \"\"\"Answer template for simple arithmetic.\"\"\"\n    result: int = Field(description=\"The numerical result\")\n\n    def model_post_init(self, __context):\n        self.correct = {\"result\": 4}\n\n    def verify(self) -> bool:\n        return self.result == self.correct[\"result\"]\n",
          "programmingLanguage": "Python"
        },
        "keywords": ["arithmetic", "math"]
      }
    }
  ]

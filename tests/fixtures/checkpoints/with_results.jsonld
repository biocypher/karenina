  "dataFeedElement": [
    {
      "@type": "DataFeedItem",
      "@id": "urn:karenina:test:q002",
      "dateCreated": "2025-01-11T00:00:00Z",
      "dateModified": "2025-01-11T12:00:00Z",
      "item": {
        "@type": "Question",
        "@id": "urn:karenina:test:q002-question",
        "text": "What is the capital of France?",
        "acceptedAnswer": {
          "@type": "Answer",
          "@id": "urn:karenina:test:q002-answer",
          "text": "Paris"
        },
        "hasPart": {
          "@type": "SoftwareSourceCode",
          "@id": "urn:karenina:test:q002-template",
          "name": "Capital City Answer Template",
          "text": "from karenina.schemas.entities import BaseAnswer\nfrom pydantic import Field\n\nclass Answer(BaseAnswer):\n    capital: str = Field(description=\"The capital city name\")\n\n    def model_post_init(self, __context):\n        self.correct = {\"capital\": \"Paris\"}\n\n    def verify(self) -> bool:\n        return self.capital.strip().lower() == self.correct[\"capital\"].strip().lower()\n",
          "programmingLanguage": "Python"
        },
        "rating": [
          {
            "@type": "Rating",
            "@id": "urn:karenina:test:rubric-1",
            "name": "Citations",
            "description": "Response should include citation markers",
            "bestRating": 1,
            "worstRating": 0,
            "additionalType": "karenina:QuestionSpecificRegexTrait"
          }
        ],
        "additionalProperty": [
          {
            "@type": "PropertyValue",
            "name": "finished",
            "value": true
          },
          {
            "@type": "PropertyValue",
            "name": "custom_verification_results",
            "value": {
              "template_result": {
                "passed": true,
                "parsed_value": "Paris"
              },
              "rubric_results": {
                "Citations": {
                  "passed": true,
                  "score": 1
                }
              }
            }
          }
        ],
        "keywords": ["geography", "capitals"]
      }
    }
  ],
